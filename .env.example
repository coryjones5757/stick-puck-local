# Server (see server.mjs)
PORT=8787

# Production: serve Vite build + API on one process
NODE_ENV=production

# Cache JSON from /api/events (reduces upstream PDF/ICS traffic)
CACHE_TTL_SECONDS=90

# Upstream HTTP timeout (ICS + PDF fetches)
FETCH_TIMEOUT_MS=15000

# Per-IP limit per window for /api/*
API_RATE_LIMIT_MAX=200

# Optional: comma-separated origins for cross-origin API access, e.g.
# ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
# If unset in production, same-hostname browser Origins are allowed; others blocked.
ALLOWED_ORIGINS=
