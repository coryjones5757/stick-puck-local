# Vite: public origin for canonical URLs, Open Graph, Twitter cards, and sitemap.xml (no trailing slash).
# Local dev: http://localhost:5173 — production uses `.env.production` (https://saltypuck.com).
VITE_SITE_URL=http://localhost:5173

# Optional: shown in site footer and Terms/Privacy as a mailto link (set in production builds).
# VITE_CONTACT_EMAIL=you@example.com

# Optional: MapLibre style URL for the /rinks map (defaults to Carto Dark Matter).
# Examples:
# VITE_MAP_STYLE_URL=https://api.maptiler.com/maps/streets-v2-dark/style.json?key=YOUR_KEY
# VITE_MAP_STYLE_URL=https://api.maptiler.com/maps/satellite/style.json?key=YOUR_KEY

# Server (see server.mjs). Prefer this name so a deploy “PORT=3000” doesn’t override your local API.
SALTYPUCK_API_PORT=8787
# If unset, API_PORT or PORT is used (see vite.config.ts).
# PORT=8787

# Production: serve Vite build + API on one process
NODE_ENV=production

# Cache JSON from /api/events (reduces upstream PDF/ICS traffic)
CACHE_TTL_SECONDS=90

# Upstream HTTP timeout (ICS + PDF fetches)
FETCH_TIMEOUT_MS=15000

# Optional: SLC Sports Complex (former Steiner sheets) — Salt Lake County Amilia JSON proxy (defaults match county site).
# SLCO_AMILIA_PROXY_URL=https://www.saltlakecounty.gov/api/proxy/AmiliaConnection/GetSchedulesByCenter
# SLCO_AMILIA_CENTER_ID=slc-sports-complex
# SLCO_AMILIA_LOC_IDS=2451775,2451994

# Optional: pin Utah Olympic Oval monthly public skate PDF (otherwise tries current/nearby months:
# https://utaholympiclegacy.org/wp-content/uploads/2017/12/MONTH-PUBLIC-SKATE-CALENDAR.pdf ).
# OLYMPIC_OVAL_PUBLIC_SKATE_PDF_URL=https://utaholympiclegacy.org/wp-content/uploads/2017/12/JUNE-PUBLIC-SKATE-CALENDAR.pdf

# Optional: pin Cottonwood Heights Ice Arena (CHRC) monthly public-skate PDF
# (otherwise auto-discovered as /files/c05c57a68/{Month}+Public+Skating.pdf).
# CHRC_PUBLIC_SKATE_PDF_URL=https://www.chparksandrecut.gov/files/c05c57a68/May+Public+Skating.pdf

# Optional: merge extra venues via public Google Calendar ICS (calendar ID …@group.calendar.google.com).
# Only non-empty variables are fetched; wrong IDs fail softly with a connector note for that rink.
# SALTYPUCK_PARKCITY_ICS_CALENDAR_ID=
# SALTYPUCK_UTAH_OLYMPIC_OVAL_ICS_CALENDAR_ID=
# SALTYPUCK_ECCLES_ICS_CALENDAR_ID=
# SALTYPUCK_UTAH_MAMMOTH_ICS_CALENDAR_ID=
# SALTYPUCK_COTTONWOOD_HEIGHTS_ICS_CALENDAR_ID=

# Per-IP limit per window for /api/*
API_RATE_LIMIT_MAX=200

# Optional: pin QuickScores PDFs instead of auto-discovery from pageUrl (see server.mjs).
# ACORD_QUICKSCORES_PDF_URL=https://www.quickscores.com/downloads/...
# COUNTY_QUICKSCORES_PDF_URL=https://www.quickscores.com/downloads/...
# How long to cache resolved PDF URLs (ms). Default 3600000 (1 hour).
# QUICKSCORES_PDF_DISCOVERY_TTL_MS=3600000

# Optional: GET /api/pdf-sources lists every matching QuickScores PDF on each facility page (by month
# in the filename) and which URL the parser uses. Set a JSON path + shared secret to remember URLs
# and detect when a newer monthly PDF appears (then hasNewPdfSinceRecord is true).
# SALTYPUCK_PDF_CHECK_STATE_PATH=./data/pdf-check-state.json
# SALTYPUCK_PDF_CHECK_TOKEN=generate-a-long-random-string

# Optional: comma-separated origins for cross-origin API access, e.g.
# ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
# If unset in production, same-hostname browser Origins are allowed; others blocked.
ALLOWED_ORIGINS=
